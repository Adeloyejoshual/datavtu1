{
  "name": "vtu-platform",
  "version": "1.0.0",
  "description": "VTU Platform — Full Stack Single Structure",
  "type": "module",
  "main": "server.js",

  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server.js",
    "db:setup": "psql $DATABASE_URL -f src/database/schema.sql"
  },

  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.323.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.1",
    "recharts": "^2.12.0",
    "uuid": "^9.0.0",
    "vite": "^5.1.0",
    "zustand": "^4.5.0"
  },

  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1"
  },

  "engines": {
    "node": ">=18.0.0"
  }
}